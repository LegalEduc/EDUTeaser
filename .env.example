# ============================================
# LegalCrew Academy 환경변수
# 이 파일을 .env로 복사한 후 값을 채워주세요
# cp .env.example .env
# ============================================

# --- 사이트 URL ---
NEXT_PUBLIC_BASE_URL=https://academy.legalcrew.co.kr

# --- 이메일 (Gmail SMTP) ---
SMTP_USER=contact@legalcrew.co.kr
SMTP_PASS=                          # Google 앱 비밀번호 (16자리)
EMAIL_FROM=리걸크루 실전 압축 부트캠프 <contact@legalcrew.co.kr>

# --- DB (Neon / Netlify DB) ---
# 앱 런타임(@netlify/neon): NETLIFY_DATABASE_URL
# 마이그레이션·drizzle-kit(db:push 등): DATABASE_URL (없으면 NETLIFY_DATABASE_URL 사용)
NETLIFY_DATABASE_URL=               # postgresql://... (Netlify에도 동일 키로 설정)
DATABASE_URL=                       # 로컬에서 drizzle만 쓸 때 위와 동일 값을 넣어도 됨

# --- 보안 ---
ENCRYPTION_KEY=                     # AES-256 키 (64자리 hex)
JWT_SECRET=                         # JWT 시크릿 (임의 문자열)
ADMIN_PASSWORD_HASH=                # 어드민 비밀번호 bcrypt 해시
