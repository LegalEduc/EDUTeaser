# 사용: 프로젝트 루트에 .env.reencrypt.local 로 복사한 뒤 값 채우기
# cp scripts/reencrypt.env.example .env.reencrypt.local
# (.env*.local 는 gitignore — 커밋하지 마세요)

# 과거 키 (확인 스크립트와 동일)
# OLD_ENCRYPTION_KEY=

# 대상 (택일)
REENCRYPT_NAMES=채다은,현승진,서성민
# REENCRYPT_IDS=

# Netlify와 동일한 현재 키 (.env.local 의 ENCRYPTION_KEY 와 같게 두면 됨)
# ENCRYPTION_KEY=
